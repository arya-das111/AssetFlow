{
  "name": "assetflow-backend",
  "version": "1.0.0",
  "description": "AssetFlow Enterprise Asset & Resource Management System Backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:seed": "node prisma/seed.js",
    "db:setup": "prisma db push && npm run prisma:seed",
    "test": "jest --runInBand --detectOpenHandles --forceExit",
    "postinstall": "prisma generate && prisma db push"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.12.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.0",
    "prisma": "^5.12.1",
    "supertest": "^7.2.2"
  }
}
